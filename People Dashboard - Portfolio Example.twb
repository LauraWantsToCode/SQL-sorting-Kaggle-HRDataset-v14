        <calculation class='tableau' formula='SUM(IF [month_start] &gt; DATEADD(&apos;month&apos;, -12, {MAX([month_start])}) &#13;&#10;    THEN [is_leaver (hr_monthly_snapshot v2.csv)] END) &#13;&#10;/ &#13;&#10;AVG(IF [month_start] &gt; DATEADD(&apos;month&apos;, -12, {MAX([month_start])}) &#13;&#10;    THEN [is_active_end_month] END) / 100' />
      </column>
      <column caption='Monthly Attrition' datatype='real' name='[Calculation_2341464462036994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([is_leaver (hr_monthly_snapshot v2.csv)]) / SUM([is_active_end_month])' />
      </column>
      <column caption='% Women' datatype='real' name='[Calculation_2341464465731587]' role='measure' type='quantitative'>
